# --- Site (deja folosit în proiect) ---
NEXT_PUBLIC_SITE_URL=https://nexteraweb.ro

# --- Stripe (Dashboard → Developers → API keys) ---
# Secret: doar server (.env.local pe dev, variabile pe Hostinger / Vercel etc.)
STRIPE_SECRET_KEY=sk_test_...
# Publishable: dacă vei folosi Stripe.js pe client (opțional pentru Checkout redirect-only).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Abonament mentenanță — Products → un Price recurent lunar (RON).
# Exemplu: price_xxxxxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_PRICE_ID=

# Webhook signing secret (whsec_...) după ce adaugi endpoint-ul:
#   POST https://DOMEINUL-TAU/api/stripe/webhook
# În local: `stripe listen --forward-to 127.0.0.1:3000/api/stripe/webhook` îți dă un whsec temporar.
STRIPE_WEBHOOK_SECRET=
