# --- Site (deja folosit în proiect) ---
NEXT_PUBLIC_SITE_URL=https://nexteraweb.ro

# --- Stripe (Faza 2 — după CUI + cont bancar legat la Stripe) ---
# Până atunci: butoanele „Cumpără” rămân pe WhatsApp; API-urile de mai jos stau inactive fără chei.
#
# Pași când ești gata:
# 1. Cont Stripe (România) + verificare firmă (CUI, IBAN)
# 2. Products → 3 prețuri recurente lunare (RON): PROTECT, GROWTH, PARTNER
# 3. Completează cheile aici → .env.local (dev) și în panoul Hostinger (prod)
# 4. Webhook live: POST https://nexteraweb.ro/api/stripe/webhook
# 5. Legăm butoanele de pe /asigurare-digitala la Checkout (în loc de WhatsApp)

# Secret: doar server — niciodată în cod client sau Git
STRIPE_SECRET_KEY=sk_test_...
# Opțional pentru Stripe.js pe client (Checkout redirect-only nu îl cere)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Pachete Asigurare Digitală (price_... din Stripe Dashboard)
STRIPE_PRICE_PROTECT=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PARTNER=

# Fallback vechi (un singur preț) — poți lăsa gol dacă folosești cele 3 de mai sus
STRIPE_SUBSCRIPTION_PRICE_ID=

# Webhook signing secret (whsec_...)
# Local: stripe listen --forward-to 127.0.0.1:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
